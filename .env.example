PORT=5000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
JWT_SECRET=replace-with-long-random-secret
UPLOAD_MAX_FILE_SIZE_MB=10

# Optional Cloudflare R2 uploads
# When all R2_* values below are set, image uploads are stored in R2.
# R2_PUBLIC_URL should be your public bucket URL or custom domain, without a trailing slash.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_URL=https://pub-your-bucket-id.r2.dev
R2_UPLOAD_PREFIX=uploads

# Razorpay (required for payment endpoints)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# Public app URLs used for QR links and PDFs
FRONTEND_URL=https://your-frontend-domain.vercel.app
PUBLIC_APP_URL=https://your-frontend-domain.vercel.app
QR_BASE_URL=https://your-frontend-domain.vercel.app

# Optional auth behavior (only for dev/testing)
USE_DEFAULT_TEST_OTP=false
DEFAULT_TEST_OTP=123456

# Claim QR testing
CLAIM_TOKEN_TTL_MINUTES=10

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Cashback App" <your-email@gmail.com>
